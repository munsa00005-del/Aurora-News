# --- Database (userspace embedded Postgres) ---
DATABASE_URL="postgresql://briefxify:briefxify@127.0.0.1:5433/briefxify"
PG_PORT=5433
PG_USER=briefxify
PG_PASSWORD=briefxify
PG_DB=briefxify

# --- GNews API (https://gnews.io) ---
# Get a free key at https://gnews.io/  then paste it here.
GNEWS_API_KEY=""

# --- Gemini API — article summarizer ---
# Get keys from https://aistudio.google.com/apikey.
# Multiple keys are comma-separated and rotated automatically.
GEMINI_API_KEYS=""
# Optional; defaults to gemini-2.5-flash-lite.
GEMINI_MODEL="gemini-2.5-flash-lite"
# Number of pending articles summarized per automatic run.
AUTO_SUMMARY_BATCH_SIZE=5
# Number of pending articles summarized by the Vercel summarizer cron.
CRON_SUMMARY_BATCH_SIZE=20
# How often to sync (cron). Default every 6 hours.
SYNC_CRON="0 */6 * * *"
# Set to "true" to run a sync once on server boot if DB is empty.
SYNC_ON_BOOT="true"
# Secret that protects the sync endpoints (/api/sync, /api/cron/sync).
# On Vercel, set this env var and the Cron job sends it automatically as a Bearer token.
CRON_SECRET="generate-a-long-random-string"

# --- Admin auth ---
ADMIN_EMAIL="admin@briefxify.io"
ADMIN_PASSWORD="change-me"
# Secret used to sign admin session JWTs. Change in production.
AUTH_SECRET="generate-a-long-random-string"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="BRIEFXIFY"
