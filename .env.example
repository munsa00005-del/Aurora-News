# --- Database (userspace embedded Postgres) ---
DATABASE_URL="postgresql://orbitnews:orbitnews@127.0.0.1:5433/orbitnews"
PG_PORT=5433
PG_USER=orbitnews
PG_PASSWORD=orbitnews
PG_DB=orbitnews

# --- GNews API (https://gnews.io) ---
# Get a free key at https://gnews.io/  then paste it here.
GNEWS_API_KEY=""

# --- Groq API — article summarizer ---
# Get a free key at https://console.groq.com/keys.
# GROK_API_KEY is also supported for compatibility with older local env files.
GROQ_API_KEY=""
# Optional; defaults to llama-3.1-8b-instant.
GROQ_MODEL="llama-3.1-8b-instant"
# How often to sync (cron). Default every 6 hours.
SYNC_CRON="0 */6 * * *"
# Set to "true" to run a sync once on server boot if DB is empty.
SYNC_ON_BOOT="true"
# Secret that protects the sync endpoints (/api/sync, /api/cron/sync).
# On Vercel, set this env var and the Cron job sends it automatically as a Bearer token.
CRON_SECRET="generate-a-long-random-string"

# --- Admin auth ---
ADMIN_EMAIL="admin@orbitnews.io"
ADMIN_PASSWORD="change-me"
# Secret used to sign admin session JWTs. Change in production.
AUTH_SECRET="generate-a-long-random-string"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="OrbitNews"
